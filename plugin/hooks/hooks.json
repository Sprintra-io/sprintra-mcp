{
  "description": "Sprintra memory layer hooks — SessionStart briefing + UserPromptSubmit capture + PostToolUse capture + Stop digest + SessionEnd cleanup. Phase 6 deps (better-sqlite3) resolved via NODE_PATH from npm-installed @sprintra/plugin if present.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "_R=\"${CLAUDE_PLUGIN_ROOT}\"; [ -z \"$_R\" ] && _R=\"$HOME/.claude/plugins/sprintra\"; _NPM=\"$(npm root -g 2>/dev/null)/@sprintra/plugin/node_modules\"; NODE_PATH=\"${_NPM}:${NODE_PATH:-}\" node \"$_R/scripts/session-start.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "_R=\"${CLAUDE_PLUGIN_ROOT}\"; [ -z \"$_R\" ] && _R=\"$HOME/.claude/plugins/sprintra\"; _NPM=\"$(npm root -g 2>/dev/null)/@sprintra/plugin/node_modules\"; NODE_PATH=\"${_NPM}:${NODE_PATH:-}\" node \"$_R/scripts/user-prompt-submit.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "_R=\"${CLAUDE_PLUGIN_ROOT}\"; [ -z \"$_R\" ] && _R=\"$HOME/.claude/plugins/sprintra\"; _NPM=\"$(npm root -g 2>/dev/null)/@sprintra/plugin/node_modules\"; NODE_PATH=\"${_NPM}:${NODE_PATH:-}\" node \"$_R/scripts/post-tool-use.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "_R=\"${CLAUDE_PLUGIN_ROOT}\"; [ -z \"$_R\" ] && _R=\"$HOME/.claude/plugins/sprintra\"; _NPM=\"$(npm root -g 2>/dev/null)/@sprintra/plugin/node_modules\"; NODE_PATH=\"${_NPM}:${NODE_PATH:-}\" node \"$_R/scripts/stop.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "_R=\"${CLAUDE_PLUGIN_ROOT}\"; [ -z \"$_R\" ] && _R=\"$HOME/.claude/plugins/sprintra\"; _NPM=\"$(npm root -g 2>/dev/null)/@sprintra/plugin/node_modules\"; NODE_PATH=\"${_NPM}:${NODE_PATH:-}\" node \"$_R/scripts/session-end.js\"",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
